.calculating-page .hexagram-container{-webkit-align-items:center;display:-webkit-flex;display:-ms-flexbox;display:-webkit-box;display:flex;height:200rpx;width:200rpx;-ms-flex-align:center;align-items:center;-webkit-justify-content:center;-ms-flex-pack:center;background:-webkit-radial-gradient(circle,rgba(0,245,255,.1) 0,transparent 70%);background:radial-gradient(circle,rgba(0,245,255,.1) 0,transparent 70%);border:2rpx solid rgba(0,245,255,.3);border-radius:50%;justify-content:center}.calculating-page .hexagram-text{font-size:100rpx;font-weight:700;text-shadow:0 0 30rpx currentColor}.calculating-page .progress-container .progress-bar{background:rgba(0,245,255,.1);border-radius:4rpx;height:8rpx;overflow:hidden}.calculating-page .progress-container .progress-fill{background:-webkit-gradient(linear,left top,right top,from(#00f5ff),to(#8b00ff));background:-webkit-linear-gradient(left,#00f5ff,#8b00ff);background:linear-gradient(90deg,#00f5ff,#8b00ff);height:100%;-webkit-transition:width .1s ease;transition:width .1s ease}.calculating-page .scan-line{-webkit-animation:scan 2s linear infinite;animation:scan 2s linear infinite;background:-webkit-gradient(linear,left top,right top,from(transparent),color-stop(#00f5ff),to(transparent));background:-webkit-linear-gradient(left,transparent,#00f5ff,transparent);background:linear-gradient(90deg,transparent,#00f5ff,transparent);height:2rpx;left:0;position:fixed;right:0;top:0}.calculating-page .result-container{-webkit-animation:fadeIn .5s ease;animation:fadeIn .5s ease}@-webkit-keyframes fadeIn{from{opacity:0;-webkit-transform:translateY(20rpx);transform:translateY(20rpx)}to{opacity:1;-webkit-transform:translateY(0);transform:translateY(0)}}@keyframes fadeIn{from{opacity:0;-webkit-transform:translateY(20rpx);transform:translateY(20rpx)}to{opacity:1;-webkit-transform:translateY(0);transform:translateY(0)}}