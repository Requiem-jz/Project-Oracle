.index-page{background:#000;min-height:100vh}page{background:#000}.cyber-input{-webkit-transition:all .3s ease;transition:all .3s ease}.cyber-input:focus{border-color:#4ade80;-webkit-box-shadow:0 0 25rpx rgba(74,222,128,.5),inset 0 0 30rpx rgba(74,222,128,.1);box-shadow:0 0 25rpx rgba(74,222,128,.5),inset 0 0 30rpx rgba(74,222,128,.1)}.cyber-picker{-webkit-transition:all .3s ease;transition:all .3s ease}.cyber-picker:active{-webkit-box-shadow:0 0 20rpx rgba(202,138,4,.5);box-shadow:0 0 20rpx rgba(202,138,4,.5);-webkit-transform:scale(.98);-ms-transform:scale(.98);transform:scale(.98)}.cyber-button{overflow:hidden;position:relative}.cyber-button::before{-webkit-animation:scan 3s linear infinite;animation:scan 3s linear infinite;background:-webkit-linear-gradient(45deg,transparent,transparent 40%,rgba(74,222,128,.1) 50%,transparent 60%,transparent);background:linear-gradient(45deg,transparent,transparent 40%,rgba(74,222,128,.1) 50%,transparent 60%,transparent);content:"";height:200%;left:-50%;position:absolute;top:-50%;width:200%}@-webkit-keyframes scan{0%{-webkit-transform:translateX(-100%) translateY(-100%);transform:translateX(-100%) translateY(-100%)}100%{-webkit-transform:translateX(100%) translateY(100%);transform:translateX(100%) translateY(100%)}}@keyframes scan{0%{-webkit-transform:translateX(-100%) translateY(-100%);transform:translateX(-100%) translateY(-100%)}100%{-webkit-transform:translateX(100%) translateY(100%);transform:translateX(100%) translateY(100%)}}@-webkit-keyframes pulse-glow{0%,100%{-webkit-box-shadow:0 0 10rpx rgba(74,222,128,.5);box-shadow:0 0 10rpx rgba(74,222,128,.5);opacity:.4}50%{-webkit-box-shadow:0 0 20rpx rgba(74,222,128,.8);box-shadow:0 0 20rpx rgba(74,222,128,.8);opacity:1}}@keyframes pulse-glow{0%,100%{-webkit-box-shadow:0 0 10rpx rgba(74,222,128,.5);box-shadow:0 0 10rpx rgba(74,222,128,.5);opacity:.4}50%{-webkit-box-shadow:0 0 20rpx rgba(74,222,128,.8);box-shadow:0 0 20rpx rgba(74,222,128,.8);opacity:1}}.animate-pulse-slow{-webkit-animation:pulse-glow 2s ease-in-out infinite;animation:pulse-glow 2s ease-in-out infinite}.cyber-divider{background:-webkit-gradient(linear,left top,right top,from(transparent),color-stop(20%,rgba(74,222,128,.3)),color-stop(50%,rgba(74,222,128,.5)),color-stop(80%,rgba(74,222,128,.3)),to(transparent));background:-webkit-linear-gradient(left,transparent,rgba(74,222,128,.3) 20%,rgba(74,222,128,.5) 50%,rgba(74,222,128,.3) 80%,transparent);background:linear-gradient(90deg,transparent,rgba(74,222,128,.3) 20%,rgba(74,222,128,.5) 50%,rgba(74,222,128,.3) 80%,transparent);height:1rpx;margin:24rpx 0}.glow-text{text-shadow:0 0 5rpx currentColor,0 0 10rpx currentColor,0 0 20rpx currentColor}.flicker{-webkit-animation:flicker .15s infinite;animation:flicker .15s infinite}@-webkit-keyframes flicker{0%,100%{opacity:1}50%{opacity:.8}}@keyframes flicker{0%,100%{opacity:1}50%{opacity:.8}}