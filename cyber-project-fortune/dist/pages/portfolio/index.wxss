.portfolio-page .realm-card{background:-webkit-linear-gradient(305deg,rgba(139,0,255,.1),rgba(0,245,255,.05));background:linear-gradient(145deg,rgba(139,0,255,.1),rgba(0,245,255,.05))}.portfolio-page .project-card{-webkit-transition:all .3s ease;transition:all .3s ease}.portfolio-page .project-card:active{border-color:rgba(0,245,255,.5);-webkit-transform:scale(.98);-ms-transform:scale(.98);transform:scale(.98)}.portfolio-page .hexagram-badge{-webkit-align-items:center;display:-webkit-flex;display:-ms-flexbox;display:-webkit-box;display:flex;height:50rpx;width:50rpx;-ms-flex-align:center;align-items:center;-webkit-justify-content:center;-ms-flex-pack:center;background:rgba(255,215,0,.05);border:1rpx solid rgba(255,215,0,.3);border-radius:4rpx;justify-content:center}.portfolio-page .fortune-bars .fortune-item{-webkit-align-items:center;display:-webkit-flex;display:-ms-flexbox;display:-webkit-box;display:flex;-ms-flex-align:center;align-items:center;gap:8rpx;margin-bottom:6rpx}.portfolio-page .fortune-bars .fortune-bar{background:hsla(0,0%,100%,.1);border-radius:2rpx;-webkit-flex:1;-ms-flex:1;flex:1;height:4rpx;overflow:hidden}.portfolio-page .fortune-bars .fortune-fill{height:100%;-webkit-transition:width .3s ease;transition:width .3s ease}.portfolio-page .add-button{-webkit-align-items:center;border-radius:50%;display:-webkit-flex;display:-ms-flexbox;display:-webkit-box;display:flex;height:60rpx;width:60rpx;-ms-flex-align:center;align-items:center;-webkit-justify-content:center;-ms-flex-pack:center;-webkit-box-shadow:0 4rpx 20rpx rgba(0,245,255,.3);box-shadow:0 4rpx 20rpx rgba(0,245,255,.3);justify-content:center}.portfolio-page .empty-state{-webkit-align-items:center;display:-webkit-flex;display:-ms-flexbox;display:-webkit-box;display:flex;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column;min-height:200rpx;-ms-flex-align:center;align-items:center;-webkit-justify-content:center;-ms-flex-pack:center;justify-content:center}